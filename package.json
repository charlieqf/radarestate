{
  "name": "radarestate",
  "private": true,
  "scripts": {
    "supabase:apply": "node scripts/supabase_apply_and_load.mjs",
    "sync:applications": "node scripts/sync_application_tracker.mjs",
    "sync:proposals": "node scripts/sync_planning_proposals.mjs",
    "build:constraints": "node scripts/build_constraints_layer.mjs",
    "build:precincts": "node scripts/build_precinct_shortlist.mjs",
    "coverage:evaluate": "node scripts/evaluate_coverage_pack.mjs",
    "report:dashboard": "node scripts/generate_dashboard_report.mjs",
    "report:weekly": "node scripts/generate_weekly_radar.mjs",
    "report:deepdive": "node scripts/generate_deep_dive_memo.mjs",
    "report:deepdives": "node scripts/generate_deep_dive_batch.mjs",
    "report:pack": "node scripts/generate_client_pack.mjs",
    "report:hunter:pack": "node scripts/generate_client_pack.mjs --region-group=Hunter --label=Newcastle-Hunter --slug=newcastle-hunter --deep-dive-config=mvp/config/deep-dive-newcastle-hunter.json",
