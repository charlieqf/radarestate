    "pipeline:weekly": "node scripts/run_pipeline.mjs --mode=weekly"
  },
  "dependencies": {
    "cheerio": "^1.1.2",
    "csv-parse": "^6.2.1",
    "marked": "^15.0.12",
    "pg": "^8.20.0"
