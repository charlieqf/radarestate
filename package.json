    "report:hunter": "node scripts/generate_region_bundle.mjs --region-group=Hunter --label=Newcastle-Hunter --slug=newcastle-hunter",
    "report:hunter:deepdives": "node scripts/generate_deep_dive_batch.mjs --config=mvp/config/deep-dive-newcastle-hunter.json",
